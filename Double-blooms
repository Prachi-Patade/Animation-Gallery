        b1 = tk.Button(exit_button_frame, text="Exit", fg="White", width=10, height=1,
                       font=("Edwardian Script ITC", 20, "bold"), bg="#46000D",
                       borderwidth=0, highlightthickness=0, command=t.destroy)
        b1.pack(padx=2, pady=2)
        # Download Button
        b2 = tk.Button(download_button_frame, text="Download file", fg="White", 
width=15, height=1,
                       font=("Edwardian Script ITC", 20, "bold"), bg="#46000D",
                       borderwidth=0, highlightthickness=0)
