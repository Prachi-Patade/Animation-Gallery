# Function for the "Use Code" button
def use_code(x, y):
    open_tkinter_window(x, y)
# Common button color and border color
button_color = "#46000D"
border_color = "#DFBD69"
# Function to draw button with border
def draw_button_with_border(turtle_obj, x, y, border_size, button_color):
    # Draw the border (slightly larger square)
    turtle_obj.penup()
    turtle_obj.goto(x, y)
    turtle_obj.shape("square")
    turtle_obj.shapesize(stretch_wid=border_size[0] + 0.1, stretch_len=border_size[1] 
+ 0.1)
    turtle_obj.color(border_color)
    turtle_obj.stamp()  # Stamp creates a fixed shape at the location   
    # Draw the actual button
    turtle_obj.shapesize(stretch_wid=border_size[0], stretch_len=border_size[1])
    turtle_obj.color(button_color)
# Draw the "Exit" button at the bottom left with border
exit_button = Turtle()
draw_button_with_border(exit_button, -150, -250, (2, 5), button_color)
exit_button.onclick(exit_program)  # Bind the function to the click
# Create a turtle for text on top of the "Exit" button
exit_text = Turtle()
exit_text.penup()
exit_text.goto(-150, -210)  # Position text above the button
exit_text.color("white")
exit_text.hideturtle()
exit_text.write("Exit", align="center", font=("Arial", 12, "bold"))
# Draw the "Use Code" button at the bottom right with border
use_code_button = Turtle()
draw_button_with_border(use_code_button, 150, -250, (2, 5), button_color)
use_code_button.onclick(use_code)  # Bind the function to the click
# Create a turtle for text on top of the "Use Code" button
use_code_text = Turtle()
use_code_text.penup()
use_code_text.goto(150, -210)  # Position text above the button
use_code_text.color("white")
use_code_text.hideturtle()
use_code_text.write("Use Code", align="center", font=("Arial", 12, "bold"))
# Start the drawing loop for the graphical pattern
h = 0  # Initialize hue for color cycle
for i in range(900):
 c = cs.hsv_to_rgb(i / 6, 1, 1)
 color(c)
 circle(i / 3, 90)
 lt(100)
 lt(50)
 right(10)
hideturtle()
done()
