import tkinter as tk
from PIL import Image, ImageDraw, ImageTk
def create_circle(canvas, x, y, r, **kwargs):
    """Draw a circle on the canvas."""
    return canvas.create_oval(x - r, y - r, x + r, y + r, **kwargs)
def create_circular_image(file_path, size):
    """Load an image and crop it to a circle."""
    try:
        img = Image.open(file_path).resize((size, size), Image.LANCZOS)
        mask = Image.new('L', (size, size), 0)
        draw = ImageDraw.Draw(mask)
        draw.ellipse((0, 0, size, size), fill=255) 
        circular_img = Image.new('RGBA', (size, size))
        circular_img.paste(img, (0, 0), mask)
        return ImageTk.PhotoImage(circular_img)
    except Exception as e:
        print(f"Error loading image from {file_path}: {e}")
        return None
